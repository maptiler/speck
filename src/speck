#!/bin/sh -e

BASE=/usr/local/share/speck

if [ $# -lt 2 ]; then
    echo "Usage: speck CONFIG OUTPUT [ARGS...]"
    echo "CONFIG    Pandoc defaults file"
    echo "OUTPUT    Target directory"
    echo "ARGS      Additional Pandoc arguments"
    exit 1
fi

CONFIG="$1"
TARGET="$2"
shift 2

# Remove the target directory if it exists, otherwise pandoc would fail.
if [ -e "$TARGET" ]; then
    # Check that it was generated by us for safety.
    if [ -e "$TARGET/sitemap.json" ]; then
        echo "Target directory exists, removing."
        rm -rf "$TARGET"
    else
        echo "Target directory exists and was not generated by SPECK."
        exit 1
    fi
fi

pandoc \
    --from markdown \
    --to chunkedhtml \
    --standalone \
    --strip-comments \
    --table-of-contents \
    --lua-filter "$BASE/pikchr.lua" \
    --filter pandoc-crossref \
    --metadata "crossrefYaml=$BASE/crossref.yaml" \
    --template "$BASE/speck.html" \
    --defaults "$CONFIG" \
    --output "$TARGET" \
    "$@"

cp "$BASE/speck.js" "$TARGET/speck.js"
cp "$BASE/speck.css" "$TARGET/speck.css"
